# Copy to .env.local — or run: vercel link && vercel env pull .env.local --environment=production
# See ENVIRONMENT_VARIABLES.md for full documentation.

# Required — dashboard login
NEXT_PUBLIC_DASHBOARD_PASSWORD=

# Required — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI lead analysis
DEEPSEEK_API_KEY=

# Google Calendar (unified OAuth)
QIKFILL_GOOGLE_CLIENT_ID=
QIKFILL_GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://property-dashboard-three.vercel.app/api/calendar/oauth-callback

# Email (Gmail app password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Google Sheets (lead logging)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# Maps (collections / presentations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — booking reminder cron (Vercel only)
# CRON_SECRET=
